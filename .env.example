# .env としてコピーして使う。Git にはコミットしない
# docker compose で参照される

# DB
POSTGRES_PASSWORD=changeme-strong-password

# 管理画面のログイン
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme-strong-password

# admin のバインドアドレス。Tailscale IP を指定して外に出さない
# 例: ADMIN_BIND=100.64.0.1
# 開発時は 127.0.0.1（デフォルト）でOK
ADMIN_BIND=127.0.0.1

# site のバインドアドレス。本番は 127.0.0.1 で Cloudflare Tunnel 経由公開
# Tunnel 設定前にプレビューしたい場合は Tailscale IP を入れる
SITE_BIND=127.0.0.1
